<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvrdudeUI.Views.PresetManagerWindow"
        Width="600" Height="520"
        WindowStartupLocation="CenterOwner"
        Title="Preset manager">
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16" ColumnDefinitions="*,Auto,Auto,Auto">

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                   Text="Selected preset (used by New/Rename/Overwrite):"
                   FontWeight="SemiBold" Margin="0,0,0,4"/>

        <ComboBox  Grid.Row="1" Grid.Column="0" Name="CbPresets"
                   HorizontalAlignment="Stretch"/>
        <Button    Grid.Row="1" Grid.Column="1" Content="New…"       Margin="6,0,0,0" Click="OnNewClick"/>
        <Button    Grid.Row="1" Grid.Column="2" Content="Rename…"    Margin="6,0,0,0" Click="OnRenameClick"/>
        <Button    Grid.Row="1" Grid.Column="3" Content="Overwrite"  Margin="6,0,0,0" Click="OnOverwriteClick"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                   Text="Delete / Export (multi-select):"
                   FontWeight="SemiBold" Margin="0,16,0,4"
                   VerticalAlignment="Top"/>
        <ListBox   Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                   Name="LbExport" Margin="0,24,0,0"
                   SelectionMode="Multiple,Toggle"
                   BorderBrush="#333" BorderThickness="1"/>

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4"
                    Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Delete selected" Click="OnDeleteClick"/>
            <Button Content="Export selected…" Click="OnExportClick"/>
            <Button Content="Import…" Click="OnImportClick"/>
        </StackPanel>

        <Button Grid.Row="4" Grid.Column="3"
                Content="Close"
                IsDefault="True"
                IsCancel="True"
                MinWidth="80"
                Margin="0,16,0,0"
                Click="OnCloseClick"/>
    </Grid>
</Window>
