<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvrdudeUI.Views.AboutWindow"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Title="About AvrdudeUI">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Name="AboutText"
                   TextWrapping="Wrap"
                   FontSize="13"/>

        <TextBlock Margin="0,6,0,0" FontWeight="SemiBold">Original project</TextBlock>
        <HyperlinkButton NavigateUri="https://blog.zakkemble.net/avrdudess-a-gui-for-avrdude/"
                         Content="https://blog.zakkemble.net/avrdudess-a-gui-for-avrdude/"
                         Padding="0,2"/>
        <HyperlinkButton NavigateUri="https://github.com/ZakKemble/AVRDUDESS"
                         Content="https://github.com/ZakKemble/AVRDUDESS"
                         Padding="0,2"/>

        <TextBlock Margin="0,10,0,0" FontStyle="Italic" FontSize="11" Opacity="0.7"
                   TextWrapping="Wrap">
            AvrdudeUI is a macOS-native port of AVRDUDESS built on Avalonia + .NET 10.
        </TextBlock>

        <Button HorizontalAlignment="Stretch"
                Content="OK"
                IsDefault="True"
                IsCancel="True"
                Margin="0,16,0,0"
                Click="OnOkClick"/>
    </StackPanel>
</Window>
